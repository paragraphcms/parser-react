{
  "name": "@paragraphcms/parser-react",
  "version": "0.3.0",
  "description": "React renderer for Paragraph CMS content.",
  "license": "MIT",
  "author": "Paragraph CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run check && npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@paragraphcms/components": "^0.2.1",
    "html-react-parser": "^5.1.12",
    "marked": "^15.0.12",
    "sanitize-html": "^2.15.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/sanitize-html": "^2.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.8.3"
  }
}
